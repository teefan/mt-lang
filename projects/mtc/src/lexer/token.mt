public enum TokenKind: ubyte
    identifier        = 1
    integer_literal   = 2
    float_literal     = 3
    string_literal    = 4
    char_literal      = 5
    cstring_literal   = 6
    indent            = 7
    dedent            = 8
    newline           = 9
    colon             = 10
    arrow             = 11
    comma             = 12
    dot               = 13
    question_mark     = 14
    ellipsis          = 15
    attr_open         = 16
    bracket_close     = 17
    paren_open        = 18
    paren_close       = 19
    bracket_open      = 20
    op_assign         = 21
    op_add            = 22
    op_sub            = 23
    op_mul            = 24
    op_div            = 25
    op_mod            = 26
    op_eq             = 27
    op_ne             = 28
    op_lt             = 29
    op_le             = 30
    op_gt             = 31
    op_ge             = 32
    op_and            = 33
    op_or             = 34
    op_not            = 35
    op_bit_and        = 36
    op_bit_or         = 37
    op_bit_xor        = 38
    op_bit_not        = 39
    op_shl            = 40
    op_shr            = 41
    keyword           = 42
    eof               = 43
    error             = 44

