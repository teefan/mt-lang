    kw_const            = 10
    kw_var              = 11
    kw_let              = 12
    kw_type             = 13
    kw_if               = 14
    kw_else             = 15
    kw_while            = 16
    kw_for              = 17
    kw_match            = 18
    kw_return           = 19
    kw_break            = 20
    kw_continue         = 21
    kw_pass             = 22
    kw_defer            = 23
    kw_unsafe           = 24
    kw_inline           = 25
    kw_when             = 26
    kw_emit             = 27
    kw_static_assert    = 28
    kw_import           = 29
    kw_public           = 30
    kw_external         = 31
    kw_foreign          = 32
    kw_async            = 33
    kw_await            = 34
    kw_and              = 35
    kw_or               = 36
    kw_not              = 37
    kw_is               = 38
    kw_in               = 39
    kw_out              = 40
    kw_inout            = 41
    kw_as               = 42
    kw_else_if          = 43
    kw_ref              = 44
    kw_ptr              = 45
    kw_span             = 46
    kw_array            = 47
    kw_attribute        = 48
    kw_event            = 49
    kw_parallel         = 50
    kw_detach           = 51
    kw_gather           = 52
    kw_do               = 53
    kw_implements       = 54
    kw_size_of          = 55
    kw_align_of         = 56
    kw_offset_of        = 57
    kw_consuming        = 58
    kw_editable         = 59
    kw_static           = 60
    kw_null             = 61
    kw_true             = 62
    kw_false            = 63
    kw_with             = 64
    kw_adapt            = 65
    kw_dyn              = 66
