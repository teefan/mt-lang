<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title><%= @title || "Milk Tea" %> &mdash; Documentation</title>
<link rel="stylesheet" href="/css/docs.css">
</head>
<body>

<div class="progress" id="progress"></div>
<div class="overlay" id="overlay"></div>

<aside class="sidebar" id="sidebar">
  <div class="sidebar-logo">
    <a href="/" style="color:inherit;text-decoration:none;display:flex;align-items:center;gap:.5rem">
      <span class="icon">&#129483;</span>
      Milk Tea
    </a>
  </div>
  <div class="sidebar-search">
    <input type="text" id="mod-filter" placeholder="Filter modules&hellip;" autocomplete="off">
  </div>
  <nav class="sidebar-nav">
    <a href="/" class="<%= active?("/") %>">Reference</a>

    <div class="stdlib-section">
      <% categorized_modules.each do |category, mods| %>
        <details open class="mod-category">
          <summary><%= category %></summary>
          <% mods.each do |mod| %>
            <a href="/stdlib/<%= mod[:name] %>" class="mod-link <%= "active" if @name == mod[:name] %>" data-mod="<%= mod[:name] %>">
              <%= mod[:name] %>
            </a>
          <% end %>
        </details>
      <% end %>
    </div>
  </nav>
  <div class="sidebar-footer">
    <button class="theme-btn" id="theme-toggle" aria-label="Toggle theme">
      <span class="icon-sun">&#9728;</span>
      <span class="icon-moon">&#127769;</span>
    </button>
    <span>Milk Tea</span>
  </div>
</aside>

<div class="topbar">
  <button class="menu-btn" id="menu-btn" aria-label="Toggle menu">&#9776;</button>
  <span class="logo-text">&#127861; Milk Tea</span>
  <button class="theme-btn" id="theme-toggle-mbl" aria-label="Toggle theme" style="margin-left:auto">&#127769;</button>
</div>

<main class="main" id="main">
  <% if @breadcrumbs %>
    <nav class="breadcrumbs">
      <% @breadcrumbs.each_with_index do |(label, href), i| %>
        <% if i > 0 %><span class="bc-sep">/</span><% end %>
        <% if href %><a href="<%= href %>"><%= label %></a><% else %><span><%= label %></span><% end %>
      <% end %>
    </nav>
  <% end %>
  <%= yield %>
</main>

<script src="/js/docs.js"></script>
</body>
</html>
