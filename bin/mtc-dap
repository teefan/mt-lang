#!/usr/bin/env ruby
# frozen_string_literal: true

$LOAD_PATH.unshift(File.expand_path("../lib", __dir__))

# --perf          log DAP requests that exceed the slow threshold
# --perf=verbose  log every DAP request
ARGV.delete_if do |arg|
  case arg
  when '--perf'          then ENV['MILK_TEA_DAP_PERF'] ||= '1';       true
  when '--perf=verbose'  then ENV['MILK_TEA_DAP_PERF'] = 'verbose';   true
  end
end

require "milk_tea"

server = MilkTea::DAP::Server.new
server.run
