{
  "module_name": "std.raymath",
  "raw_module_name": "std.c.raymath",
  "raw_import_alias": "c",
  "types": {
    "exclude": ["Float3Array", "Float16Array"]
  },
  "constants": {},
  "functions": {
    "overrides": [
      {
        "raw": "Vector3OrthoNormalize",
        "params": [
          { "name": "v1", "mode": "inout", "type": "rl.Vector3" },
          { "name": "v2", "mode": "inout", "type": "rl.Vector3" }
        ]
      },
      {
        "raw": "QuaternionToAxisAngle",
        "params": [
          { "name": "q", "type": "rl.Quaternion" },
          { "name": "axis", "mode": "out", "type": "rl.Vector3" },
          { "name": "angle", "mode": "out", "type": "float" }
        ]
      },
      {
        "raw": "MatrixDecompose",
        "params": [
          { "name": "mat", "type": "rl.Matrix" },
          { "name": "translation", "mode": "out", "type": "rl.Vector3" },
          { "name": "rotation", "mode": "out", "type": "rl.Quaternion" },
          { "name": "scale", "mode": "out", "type": "rl.Vector3" }
        ]
      },
      {
        "raw": "Vector3ToFloatV",
        "return_type": "array[float, 3]",
        "mapping": "c.Vector3ToFloatV(v).v"
      },
      {
        "raw": "MatrixToFloatV",
        "return_type": "array[float, 16]",
        "mapping": "c.MatrixToFloatV(mat).v"
      }
    ]
  }
}
