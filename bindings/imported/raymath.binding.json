{
  "module_name": "std.raymath",
  "raw_module_name": "std.c.raymath",
  "raw_import_alias": "c",
  "types": {
    "exclude": ["Float3Array", "Float16Array"],
    "native_types": {
      "Vector2": "vec2",
      "Vector3": "vec3",
      "Vector4": "vec4",
      "Matrix": "mat4",
      "Quaternion": "quat"
    }
  },
  "constants": {},
  "functions": {
    "overrides": [
      {
        "raw": "Vector3OrthoNormalize",
        "params": [
          { "name": "v1", "mode": "inout", "type": "vec3" },
          { "name": "v2", "mode": "inout", "type": "vec3" }
        ]
      },
      {
        "raw": "QuaternionToAxisAngle",
        "params": [
          { "name": "q", "type": "quat" },
          { "name": "axis", "mode": "out", "type": "vec3" },
          { "name": "angle", "mode": "out", "type": "float" }
        ]
      },
      {
        "raw": "MatrixDecompose",
        "params": [
          { "name": "mat", "type": "mat4" },
          { "name": "translation", "mode": "out", "type": "vec3" },
          { "name": "rotation", "mode": "out", "type": "quat" },
          { "name": "scale", "mode": "out", "type": "vec3" }
        ]
      },
      {
        "raw": "Vector3ToFloatV",
        "return_type": "array[float, 3]",
        "mapping": "c.Vector3ToFloatV(v).v"
      },
      {
        "raw": "MatrixToFloatV",
        "return_type": "array[float, 16]",
        "mapping": "c.MatrixToFloatV(mat).v"
      }
    ]
  }
}
