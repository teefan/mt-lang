  "constants": {
    "strip_prefix": "GLFW_"
  },
  "functions": {
    "include_prefixes": [
      "glfw"
    ],
    "overrides": [
      {
        "raw": "glfwInit",
        "return_type": "bool",
        "mapping": "c.glfwInit() != 0"
      },
      {
        "raw": "glfwWindowShouldClose",
        "return_type": "bool",
        "mapping": "c.glfwWindowShouldClose(window) != 0"
      },
      {
        "raw": "glfwRawMouseMotionSupported",
        "return_type": "bool",
        "mapping": "c.glfwRawMouseMotionSupported() != 0"
      },
      {
        "raw": "glfwJoystickPresent",
        "return_type": "bool",
        "mapping": "c.glfwJoystickPresent(jid) != 0"
      },
      {
        "raw": "glfwJoystickIsGamepad",
        "return_type": "bool",
        "mapping": "c.glfwJoystickIsGamepad(jid) != 0"
      },
      {
        "raw": "glfwGetGamepadState",
        "return_type": "bool",
        "mapping": "c.glfwGetGamepadState(jid, state) != 0"
      },
      {
        "raw": "glfwExtensionSupported",
        "return_type": "bool",
        "mapping": "c.glfwExtensionSupported(extension) != 0"
      },
      {
        "raw": "glfwVulkanSupported",
        "return_type": "bool",
        "mapping": "c.glfwVulkanSupported() != 0"
      }
    ],
    "strip_prefix": "glfw"
  }
