{
  "module_name": "std.steamworks",
  "raw_module_name": "std.c.steamworks",
  "raw_import_alias": "c",
  "imports": [
    {
      "module_name": "std.str",
      "alias": "text"
    }
  ],
  "types": {
    "rename_rules": [
      {
        "kind": "prefix",
        "match": "ISteam"
      },
      {
        "kind": "prefix",
        "match": "ESteam",
        "replace_with": "E"
      },
      {
        "kind": "prefix",
        "match": "Steam"
      }
    ]
  },
  "constants": {},
  "functions": {
    "overrides": [
      {
        "raw": "SteamAPI_ISteamFriends_GetPersonaName",
        "return_type": "str",
        "mapping": "text.cstr_as_str(c.SteamAPI_ISteamFriends_GetPersonaName(self))"
      }
    ],
    "rename_rules": [
      {
        "kind": "prefix",
        "match": "SteamAPI_ISteam"
      },
      {
        "kind": "prefix",
        "match": "SteamAPI_Steam"
      },
      {
        "kind": "prefix",
        "match": "SteamAPI_"
      },
      {
        "kind": "prefix",
        "match": "SteamInternal_",
        "replace_with": "Internal_"
      },
      {
        "kind": "replace",
        "match": "_SteamAPI_",
        "replace_with": "_"
      }
    ]
  }
}
