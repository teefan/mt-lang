          { "name": "compile_context", "type": "ptr[CompileContext]" }
        ],
        "return_type": "ptr[Code]?",
        "mapping": "c.pcre2_compile_8(pattern.data, ptr_uint<-pattern.len, options, error_code, error_offset, compile_context)"
      },
      {
        "raw": "pcre2_match_8",
        "name": "match_bytes",
        "params": [
          { "name": "code", "type": "const_ptr[Code]" },
          { "name": "subject", "type": "span[ubyte]" },
          { "name": "start_offset", "type": "ptr_uint" },
          { "name": "options", "type": "uint" },
          { "name": "match_data", "type": "ptr[MatchData]" },
          { "name": "match_context", "type": "ptr[MatchContext]" }
        ],
        "return_type": "int",
        "mapping": "c.pcre2_match_8(code, subject.data, ptr_uint<-subject.len, start_offset, options, match_data, match_context)"
      },
      {
        "raw": "pcre2_get_error_message_8",
        "name": "get_error_message",
        "params": [
          { "name": "error_code", "type": "int" },
          { "name": "buffer", "type": "span[ubyte]" }
        ],
        "return_type": "int",
        "mapping": "c.pcre2_get_error_message_8(error_code, buffer.data, ptr_uint<-buffer.len)"
      }
    ]
