{
  "name": "milk-tea-lang",
  "displayName": "Milk Tea",
  "description": "Language support, LSP, and DAP integration for the Milk Tea programming language (.mt files)",
  "version": "0.1.0",
  "publisher": "milk-tea-lang",
  "license": "MIT",
  "engines": {
    "vscode": "^1.82.0"
  },
  "categories": [
    "Programming Languages",
    "Debuggers",
    "Linters",
    "Formatters"
  ],
  "keywords": [
    "milk-tea",
    "milktea",
    "mt"
  ],
  "activationEvents": [
    "onDebug:milk-tea"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "milk-tea",
        "aliases": [
          "Milk Tea",
          "milktea"
        ],
        "extensions": [
          ".mt"
        ],
        "configuration": "./language-configuration.json",
        "icon": {
          "light": "./icons/milk-tea-light.svg",
          "dark": "./icons/milk-tea-dark.svg"
        }
      }
    ],
    "grammars": [
      {
        "language": "milk-tea",
        "scopeName": "source.milk-tea",
        "path": "./syntaxes/milk-tea.tmLanguage.json"
      }
    ],
    "configuration": {
      "title": "Milk Tea",
      "properties": {
        "milkTea.lsp.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable the Milk Tea language server (LSP). Restart VS Code or run 'Milk Tea: Restart LSP' after changing."
        },
        "milkTea.lsp.serverPath": {
          "type": "string",
          "default": "mtc-lsp",
          "description": "Path to the mtc-lsp binary. Accepts an absolute path or a name on $PATH."
        },
        "milkTea.lsp.extraArgs": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Extra command-line arguments passed to 'mtc lsp'."
        },
        "milkTea.lsp.logLevel": {
          "type": "string",
          "enum": [
            "off",
            "error",
            "warn",
            "info",
            "debug",
            "trace"
          ],
          "enumDescriptions": [
            "No logging.",
            "Only errors.",
            "Errors and warnings.",
            "Errors, warnings, and informational messages.",
            "Verbose debug output.",
            "Full protocol trace (very noisy)."
          ],
          "default": "info",
          "description": "Controls how much Milk Tea LSP output is written to the 'Milk Tea LSP' output channel."
        },
        "milkTea.lsp.traceServer": {
          "type": "string",
          "enum": [
            "off",
            "messages",
            "verbose"
          ],
          "default": "off",
          "description": "Traces the raw JSON-RPC communication between VS Code and the Milk Tea language server."
        },
        "milkTea.lsp.retry.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Retry LSP startup when the language server cannot be started or connected."
        },
        "milkTea.lsp.retry.maxAttempts": {
          "type": "number",
          "default": 3,
          "minimum": 1,
          "description": "Maximum number of LSP startup attempts (including the first attempt)."
        },
        "milkTea.lsp.retry.delaySeconds": {
          "type": "number",
          "default": 10,
          "minimum": 1,
          "description": "Delay in seconds between LSP retry attempts."
        },
        "milkTea.dap.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable the Milk Tea debug adapter (DAP)."
        },
        "milkTea.dap.serverPath": {
          "type": "string",
          "default": "mtc-dap",
          "description": "Path to the mtc-dap binary. Accepts an absolute path or a name on $PATH."
        },
        "milkTea.dap.extraArgs": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Extra command-line arguments passed to 'mtc dap'."
        },
        "milkTea.dap.logLevel": {
          "type": "string",
          "enum": [
            "off",
            "error",
            "warn",
            "info",
            "debug",
            "trace"
          ],
          "enumDescriptions": [
            "No DAP logging.",
            "Only DAP errors.",
            "DAP errors and warnings.",
            "Session lifecycle plus key launch/configuration protocol messages.",
            "All DAP message summaries.",
            "Full DAP protocol trace with sensitive fields redacted."
          ],
          "default": "info",
          "description": "Controls how much Milk Tea DAP output is written to the 'Milk Tea DAP' output channel."
        },
        "milkTea.dap.retry.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Retry DAP session launch when the debug adapter fails to connect."
        },
        "milkTea.dap.retry.maxAttempts": {
          "type": "number",
          "default": 3,
          "minimum": 1,
          "description": "Maximum number of DAP launch attempts per debug session."
        },
        "milkTea.dap.retry.delaySeconds": {
          "type": "number",
          "default": 10,
          "minimum": 1,
          "description": "Delay in seconds between DAP retry attempts."
        },
        "milkTea.format.mode": {
          "type": "string",
          "enum": [
            "tidy",
            "preserve",
            "safe",
            "canonical"
          ],
          "enumDescriptions": [
            "Preserves line structure and multi-line calls; normalizes inline whitespace (recommended).",
            "Fully verbatim — keeps all spacing and alignment as written.",
            "Full AST re-emit: normalizes everything including multi-line call layout.",
            "Alias for safe."
          ],
          "default": "tidy",
          "description": "Controls how the Milk Tea formatter rewrites source files on save or format."
        }
      }
    },
    "commands": [
      {
        "command": "milkTea.restartLsp",
        "title": "Restart LSP",
        "category": "Milk Tea"
      },
      {
        "command": "milkTea.viewLspLogs",
        "title": "View LSP Logs",
        "category": "Milk Tea"
      },
      {
        "command": "milkTea.viewDapLogs",
        "title": "View DAP Logs",
        "category": "Milk Tea"
      },
      {
        "command": "milkTea.restartDap",
        "title": "Restart DAP (Stop Active Sessions)",
        "category": "Milk Tea"
      }
    ],
    "breakpoints": [
      {
        "language": "milk-tea"
      }
    ],
    "debuggers": [
      {
        "type": "milk-tea",
        "label": "Milk Tea",
        "languages": [
          "milk-tea"
        ],
        "configurationAttributes": {
          "launch": {
            "required": [
              "program"
            ],
            "properties": {
              "backend": {
                "type": "string",
                "enum": [
                  "lldb-dap",
                  "process"
                ],
                "default": "lldb-dap",
                "description": "Debug backend to use. Use lldb-dap for native debugging features."
              },
              "adapterPath": {
                "type": "string",
                "description": "Optional path to the lldb-dap executable used by the Milk Tea adapter."
              },
              "program": {
                "type": "string",
                "description": "Absolute path to the Milk Tea source file (.mt) to compile and debug.",
                "default": "${file}"
              },
              "noDebug": {
                "type": "boolean",
                "default": false,
                "description": "Run without attaching the debugger. VS Code sets this automatically for Ctrl+F5."
              },
              "args": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "default": [],
                "description": "Command-line arguments passed to the debugged program."
              },
              "cwd": {
                "type": "string",
                "default": "${workspaceFolder}",
                "description": "Working directory for the debugged program."
              },
              "stopOnEntry": {
                "type": "boolean",
                "default": false,
                "description": "Automatically stop at the program entry point."
              },
              "env": {
                "type": "object",
                "additionalProperties": {
                  "type": "string"
                },
                "default": {},
                "description": "Environment variables set for the debugged program."
              },
              "sourceMap": {
                "type": "object",
                "additionalProperties": {
                  "type": "string"
                },
                "default": {},
                "description": "Optional source remapping passed through to lldb-dap."
              },
              "preInitCommands": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "default": [],
                "description": "LLDB commands to run before adapter initialization."
              },
              "initCommands": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "default": [],
                "description": "LLDB commands to run during session initialization."
              },
              "preRunCommands": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "default": [],
                "description": "LLDB commands to run after launch/attach and before execution continues."
              },
              "postRunCommands": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "default": [],
                "description": "LLDB commands to run after the target starts."
              },
              "coreFile": {
                "type": "string",
                "description": "Optional core file path for post-mortem debugging."
              }
            }
          },
          "attach": {
            "properties": {
              "backend": {
                "type": "string",
                "enum": [
                  "lldb-dap",
                  "process"
                ],
                "default": "lldb-dap",
                "description": "Debug backend to use. Attach requires lldb-dap."
              },
              "adapterPath": {
                "type": "string",
                "description": "Optional path to the lldb-dap executable used by the Milk Tea adapter."
              },
              "program": {
                "type": "string",
                "description": "Optional executable or Milk Tea source used to provide symbols when attaching."
              },
              "pid": {
                "type": [
                  "number",
                  "string"
                ],
                "description": "Process ID to attach to."
              },
              "processName": {
                "type": "string",
                "description": "Process name to attach to when supported by lldb-dap."
              },
              "waitFor": {
                "type": "boolean",
                "default": false,
                "description": "Wait for the named process to appear before attaching."
              },
              "cwd": {
                "type": "string",
                "default": "${workspaceFolder}",
                "description": "Working directory used for relative debugger paths."
              },
              "env": {
                "type": "object",
                "additionalProperties": {
                  "type": "string"
                },
                "default": {},
                "description": "Environment variables available to debugger-launched helper processes."
              },
              "sourceMap": {
                "type": "object",
                "additionalProperties": {
                  "type": "string"
                },
                "default": {},
                "description": "Optional source remapping passed through to lldb-dap."
              },
              "preInitCommands": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "default": [],
                "description": "LLDB commands to run before adapter initialization."
              },
              "initCommands": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "default": [],
                "description": "LLDB commands to run during session initialization."
              },
              "preRunCommands": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "default": [],
                "description": "LLDB commands to run after attach and before execution continues."
              },
              "postRunCommands": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "default": [],
                "description": "LLDB commands to run after the attach completes."
              },
              "coreFile": {
                "type": "string",
                "description": "Optional core file path for post-mortem debugging."
              }
            }
          }
        },
        "initialConfigurations": [
          {
            "type": "milk-tea",
            "request": "launch",
            "name": "Debug Milk Tea Program",
            "backend": "lldb-dap",
            "program": "${file}",
            "args": [],
            "stopOnEntry": false
          },
          {
            "type": "milk-tea",
            "request": "attach",
            "name": "Attach to Process",
            "backend": "lldb-dap",
            "pid": 12345
          }
        ],
        "configurationSnippets": [
          {
            "label": "Milk Tea: Launch",
            "description": "Launch and debug a Milk Tea program.",
            "body": {
              "type": "milk-tea",
              "request": "launch",
              "name": "${1:Debug Milk Tea Program}",
              "backend": "lldb-dap",
              "program": "${file}",
              "args": [],
              "stopOnEntry": false
            }
          },
          {
            "label": "Milk Tea: Attach",
            "description": "Attach LLDB to a running native process.",
            "body": {
              "type": "milk-tea",
              "request": "attach",
              "name": "${1:Attach to Process}",
              "backend": "lldb-dap",
              "pid": "${2:12345}"
            }
          }
        ]
      }
    ]
  },
  "scripts": {
    "compile": "tsc -p .",
    "watch": "tsc -p . --watch",
    "lint": "eslint src --ext ts",
    "snapshot:tm": "node ./scripts/snapshot-textmate.js",
    "package": "npm run compile && vsce package --allow-missing-repository --skip-license",
    "vsix:build": "npm run package",
    "vscode:install": "code --install-extension \"${npm_package_name}-${npm_package_version}.vsix\" --force",
    "vscode:uninstall": "code --uninstall-extension milk-tea-lang.milk-tea-lang",
    "vscode:reinstall": "npm run vscode:uninstall && npm run vsix:build && npm run vscode:install"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.82.0",
    "@vscode/vsce": "^2.24.0",
    "typescript": "^5.3.0",
    "vscode-oniguruma": "^2.0.1",
    "vscode-textmate": "^9.3.2"
  }
}
