{
  "comments": {
    "lineComment": "#"
  },
  "brackets": [
    ["(", ")"],
    ["[", "]"]
  ],
  "autoClosingPairs": [
    { "open": "(", "close": ")" },
    { "open": "[", "close": "]" },
    { "open": "\"", "close": "\"", "notIn": ["string", "comment"] }
  ],
  "surroundingPairs": [
    { "open": "(", "close": ")" },
    { "open": "[", "close": "]" },
    { "open": "\"", "close": "\"" }
  ],
  "indentationRules": {
    "increaseIndentPattern": ":\\s*(#.*)?$",
    "decreaseIndentPattern": "^\\s*(elif|else)\\b"
  },
  "onEnterRules": [
    {
      "beforeText": ":\\s*(#.*)?$",
      "action": { "indent": "indent" }
    }
  ],
  "wordPattern": "[a-zA-Z_][a-zA-Z0-9_]*"
}
