{
  "comments": {
    "lineComment": { "comment": "#" }
  },
  "brackets": [
    ["(", ")"],
    ["[", "]"]
  ],
  "autoClosingPairs": [
    { "open": "(", "close": ")" },
    { "open": "[", "close": "]" },
    { "open": "\"", "close": "\"", "notIn": ["string", "comment"] }
  ],
  "surroundingPairs": [
    { "open": "(", "close": ")" },
    { "open": "[", "close": "]" },
    { "open": "\"", "close": "\"" }
  ],
  "folding": {
    "offSide": true
  },
  "onEnterRules": [
    {
      "beforeText": "^\\s*(public\\s+)?(const\\s+)?(function|async|editable|struct|enum|flags|variant|union|interface|if|elif|else|while|for|match|unsafe|extending|defer|when)\\b.*:\\s*$",
      "action": { "indent": "indent" }
    }
  ],
  "wordPattern": "[a-zA-Z_][a-zA-Z0-9_]*"
}
