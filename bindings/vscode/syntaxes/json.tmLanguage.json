{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Vendored JSON",
  "scopeName": "source.json",
  "patterns": [
    { "include": "#property-key" },
    { "include": "#string" },
    { "include": "#number" },
    { "include": "#keyword" },
    { "include": "#punctuation" }
  ],
  "repository": {
    "property-key": {
      "name": "support.type.property-name.json",
      "match": "\"(?:\\\\.|[^\"\\\\])*\"(?=\\s*:)",
      "captures": {
        "0": { "name": "support.type.property-name.json" }
      }
    },
    "string": {
      "name": "string.quoted.double.json",
      "begin": "\"",
      "beginCaptures": {
        "0": { "name": "punctuation.definition.string.begin.json" }
      },
      "end": "\"",
      "endCaptures": {
        "0": { "name": "punctuation.definition.string.end.json" }
      },
      "patterns": [
        {
          "name": "constant.character.escape.json",
          "match": "\\\\(?:[\"\\/bfnrt]|u[0-9a-fA-F]{4})"
        },
        {
          "name": "invalid.illegal.escape.json",
          "match": "\\\\."
        }
      ]
    },
    "number": {
      "name": "constant.numeric.json",
      "match": "-?(?:0|[1-9][0-9]*)(?:\\.[0-9]+)?(?:[eE][+-]?[0-9]+)?\\b"
    },
    "keyword": {
      "patterns": [
        {
          "name": "constant.language.boolean.json",
          "match": "\\b(?:true|false)\\b"
        },
        {
          "name": "constant.language.null.json",
          "match": "\\bnull\\b"
        }
      ]
    },
    "punctuation": {
      "patterns": [
        { "name": "punctuation.separator.key-value.json", "match": ":" },
        { "name": "punctuation.separator.array.json", "match": "," },
        { "name": "punctuation.definition.dictionary.begin.json", "match": "\\{" },
        { "name": "punctuation.definition.dictionary.end.json", "match": "\\}" },
        { "name": "punctuation.definition.array.begin.json", "match": "\\[" },
        { "name": "punctuation.definition.array.end.json", "match": "\\]" }
      ]
    }
  }
}
