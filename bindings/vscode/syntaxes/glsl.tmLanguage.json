{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Vendored GLSL",
  "scopeName": "source.glsl",
  "patterns": [
    { "include": "#comment-line" },
    { "include": "#comment-block" },
    { "include": "#preprocessor" },
    { "include": "#string" },
    { "include": "#number" },
    { "include": "#keyword-control" },
    { "include": "#storage-qualifier" },
    { "include": "#type" },
    { "include": "#builtin-variable" },
    { "include": "#builtin-function" },
    { "include": "#keyword-other" },
    { "include": "#function-call" },
    { "include": "#operator" },
    { "include": "#punctuation" }
  ],
  "repository": {
    "comment-line": {
      "name": "comment.line.double-slash.glsl",
      "match": "//.*$"
    },
    "comment-block": {
      "name": "comment.block.glsl",
      "begin": "/\\*",
      "end": "\\*/"
    },
    "preprocessor": {
      "name": "meta.preprocessor.glsl",
      "match": "^\\s*#\\s*(?:version|define|undef|if|ifdef|ifndef|elif|else|endif|error|pragma|extension|line|include)\\b.*$"
    },
    "string": {
      "name": "string.quoted.double.glsl",
      "begin": "\"",
      "end": "\"",
      "patterns": [
        {
          "name": "constant.character.escape.glsl",
          "match": "\\\\."
        }
      ]
    },
    "number": {
      "patterns": [
        {
          "name": "constant.numeric.hex.glsl",
          "match": "\\b0[xX][0-9a-fA-F]+(?:u|U|l|L|ul|UL|lu|LU)?\\b"
        },
        {
          "name": "constant.numeric.float.glsl",
          "match": "\\b(?:[0-9]+\\.[0-9]*|\\.[0-9]+|[0-9]+)(?:[eE][+-]?[0-9]+)?(?:lf|LF|f|F)?\\b"
        },
        {
          "name": "constant.numeric.integer.glsl",
          "match": "\\b[0-9]+(?:u|U|l|L|ul|UL|lu|LU)?\\b"
        }
      ]
    },
    "keyword-control": {
      "name": "keyword.control.glsl",
      "match": "\\b(?:if|else|switch|case|default|for|while|do|break|continue|return|discard)\\b"
    },
    "storage-qualifier": {
      "name": "storage.modifier.glsl",
      "match": "\\b(?:const|in|out|inout|uniform|attribute|varying|buffer|shared|coherent|volatile|restrict|readonly|writeonly|layout|centroid|flat|smooth|noperspective|patch|sample|invariant|precise|highp|mediump|lowp|subroutine)\\b"
    },
    "type": {
      "name": "support.type.glsl",
      "match": "\\b(?:void|bool|int|uint|float|double|atomic_uint|bvec[2-4]|ivec[2-4]|uvec[2-4]|vec[2-4]|dvec[2-4]|mat[2-4](?:x[2-4])?|dmat[2-4](?:x[2-4])?|sampler[1-3]D(?:Array|Shadow|MS|MSArray)?|samplerCube(?:Shadow)?|samplerBuffer|sampler2DRect(?:Shadow)?|samplerCubeArray(?:Shadow)?|isampler[1-3]D(?:Array|MS|MSArray)?|isamplerCube(?:Array)?|isamplerBuffer|isampler2DRect|usampler[1-3]D(?:Array|MS|MSArray)?|usamplerCube(?:Array)?|usamplerBuffer|usampler2DRect|image[1-3]D(?:Array|MS|MSArray)?|imageCube(?:Array)?|imageBuffer|image2DRect|iimage[1-3]D(?:Array|MS|MSArray)?|iimageCube(?:Array)?|iimageBuffer|iimage2DRect|uimage[1-3]D(?:Array|MS|MSArray)?|uimageCube(?:Array)?|uimageBuffer|uimage2DRect|struct)\\b"
    },
    "builtin-variable": {
      "name": "variable.language.builtin.glsl",
      "match": "\\bgl_[A-Za-z0-9_]+\\b"
    },
    "builtin-function": {
      "name": "support.function.builtin.glsl",
      "match": "\\b(?:radians|degrees|sin|cos|tan|asin|acos|atan|pow|exp|log|exp2|log2|sqrt|inversesqrt|abs|sign|floor|trunc|round|roundEven|ceil|fract|mod|min|max|clamp|mix|step|smoothstep|isnan|isinf|floatBitsToInt|floatBitsToUint|intBitsToFloat|uintBitsToFloat|fma|frexp|ldexp|packUnorm|packSnorm|unpackUnorm|unpackSnorm|length|distance|dot|cross|normalize|faceforward|reflect|refract|matrixCompMult|outerProduct|transpose|determinant|inverse|lessThan|greaterThan|equal|notEqual|any|all|not|texture|textureProj|textureLod|textureOffset|texelFetch|imageLoad|imageStore|barrier|memoryBarrier|EmitVertex|EndPrimitive)\\b"
    },
    "keyword-other": {
      "patterns": [
        {
          "name": "keyword.other.glsl",
          "match": "\\b(?:precision|true|false)\\b"
        }
      ]
    },
    "function-call": {
      "match": "\\b([A-Za-z_][A-Za-z0-9_]*)(?=\\s*\\()",
      "captures": {
        "1": { "name": "entity.name.function.glsl" }
      }
    },
    "operator": {
      "patterns": [
        {
          "name": "keyword.operator.assignment.glsl",
          "match": "(?:\\+=|-=|\\*=|/=|%=|<<=|>>=|&=|\\|=|\\^=|=)(?!=)"
        },
        {
          "name": "keyword.operator.comparison.glsl",
          "match": "(?:==|!=|<=|>=|<|>)"
        },
        {
          "name": "keyword.operator.arithmetic.glsl",
          "match": "(?:\\+|\\-|\\*|/|%)"
        },
        {
          "name": "keyword.operator.bitwise.glsl",
          "match": "(?:<<|>>|&&|\\|\\||!|&|\\||\\^|~|\\?|:)"
        },
        {
          "name": "keyword.operator.member.glsl",
          "match": "\\."
        }
      ]
    },
    "punctuation": {
      "patterns": [
        { "name": "punctuation.separator.comma.glsl", "match": "," },
        { "name": "punctuation.separator.semicolon.glsl", "match": ";" },
        { "name": "punctuation.section.parens.begin.glsl", "match": "\\(" },
        { "name": "punctuation.section.parens.end.glsl", "match": "\\)" },
        { "name": "punctuation.section.braces.begin.glsl", "match": "\\{" },
        { "name": "punctuation.section.braces.end.glsl", "match": "\\}" },
        { "name": "punctuation.section.brackets.begin.glsl", "match": "\\[" },
        { "name": "punctuation.section.brackets.end.glsl", "match": "\\]" }
      ]
    }
  }
}
