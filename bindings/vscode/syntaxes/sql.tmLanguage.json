{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Vendored SQL",
  "scopeName": "source.sql",
  "patterns": [
    { "include": "#comment-line" },
    { "include": "#comment-block" },
    { "include": "#string" },
    { "include": "#quoted-identifier" },
    { "include": "#number" },
    { "include": "#parameter" },
    { "include": "#keyword" },
    { "include": "#type" },
    { "include": "#function-call" },
    { "include": "#operator" },
    { "include": "#punctuation" }
  ],
  "repository": {
    "comment-line": {
      "name": "comment.line.double-dash.sql",
      "match": "--.*$"
    },
    "comment-block": {
      "name": "comment.block.sql",
      "begin": "/\\*",
      "end": "\\*/"
    },
    "string": {
      "name": "string.quoted.single.sql",
      "begin": "'",
      "beginCaptures": {
        "0": { "name": "punctuation.definition.string.begin.sql" }
      },
      "end": "'",
      "endCaptures": {
        "0": { "name": "punctuation.definition.string.end.sql" }
      },
      "patterns": [
        {
          "name": "constant.character.escape.sql",
          "match": "''"
        }
      ]
    },
    "quoted-identifier": {
      "name": "entity.name.identifier.sql",
      "begin": "\"",
      "beginCaptures": {
        "0": { "name": "punctuation.definition.identifier.begin.sql" }
      },
      "end": "\"",
      "endCaptures": {
        "0": { "name": "punctuation.definition.identifier.end.sql" }
      },
      "patterns": [
        {
          "name": "constant.character.escape.sql",
          "match": "\"\""
        }
      ]
    },
    "number": {
      "patterns": [
        {
          "name": "constant.numeric.float.sql",
          "match": "\\b[0-9]+\\.[0-9]+(?:[eE][+-]?[0-9]+)?\\b"
        },
        {
          "name": "constant.numeric.integer.sql",
          "match": "\\b[0-9]+\\b"
        }
      ]
    },
    "parameter": {
      "name": "variable.parameter.sql",
      "match": "(?:\\?(?:[0-9]+)?|[:@$][A-Za-z_][A-Za-z0-9_]*)"
    },
    "keyword": {
      "name": "keyword.control.sql",
      "match": "\\b(?:select|insert|update|delete|from|where|join|inner|left|right|full|cross|on|using|group|by|order|having|limit|offset|values|into|as|distinct|union|all|intersect|except|case|when|then|else|end|exists|between|like|glob|match|regexp|escape|and|or|not|is|in|null|collate|asc|desc|pragma|begin|transaction|commit|rollback|savepoint|release|create|alter|drop|table|index|view|trigger|with|recursive|returning|conflict|do|set)\\b"
    },
    "type": {
      "name": "support.type.sql",
      "match": "\\b(?:integer|real|text|blob|numeric|boolean|date|datetime|primary|key|unique|check|foreign|references|default|autoincrement)\\b"
    },
    "function-call": {
      "match": "\\b([A-Za-z_][A-Za-z0-9_]*)(?=\\s*\\()",
      "captures": {
        "1": { "name": "entity.name.function.sql" }
      }
    },
    "operator": {
      "patterns": [
        {
          "name": "keyword.operator.comparison.sql",
          "match": "(?:==|!=|<>|<=|>=|<|>)"
        },
        {
          "name": "keyword.operator.assignment.sql",
          "match": "="
        },
        {
          "name": "keyword.operator.arithmetic.sql",
          "match": "(?:\\+|\\-|\\*|/|%)"
        }
      ]
    },
    "punctuation": {
      "patterns": [
        { "name": "punctuation.separator.comma.sql", "match": "," },
        { "name": "punctuation.terminator.statement.sql", "match": ";" },
        { "name": "punctuation.section.group.begin.sql", "match": "\\(" },
        { "name": "punctuation.section.group.end.sql", "match": "\\)" },
        { "name": "punctuation.section.block.begin.sql", "match": "\\{" },
        { "name": "punctuation.section.block.end.sql", "match": "\\}" }
      ]
    }
  }
}
