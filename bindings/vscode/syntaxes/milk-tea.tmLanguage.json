{
  "$schema": "https://json.schemastore.org/tmlanguage.json",
  "name": "Milk Tea",
  "scopeName": "source.milk-tea",
  "fileTypes": ["mt"],
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings-and-heredocs" },
    { "include": "#character-literal" },
    { "include": "#numbers" },
    { "include": "#attribute-application" },
    { "include": "#constant-language" },
    { "include": "#function-definition" },
    { "include": "#attribute-declaration" },
    { "include": "#keyword-operator" },
    { "include": "#keyword-modifier" },
    { "include": "#keyword-builtin" },
    { "include": "#keyword-control" },
    { "include": "#keyword-declaration" },
    { "include": "#type-constructor" },
    { "include": "#type-primitive" },
    { "include": "#function-call" },
    { "include": "#type-name" },
    { "include": "#field-declaration" },
    { "include": "#identifier" },
    { "include": "#operator" },
    { "include": "#punctuation" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.documentation.milk-tea",
          "match": "##.*$"
        },
        {
          "name": "comment.line.number-sign.milk-tea",
          "match": "#.*$"
        }
      ]
    },

    "strings-and-heredocs": {
      "patterns": [
        { "include": "#format-string" },
        { "include": "#cstring" },
        { "include": "#heredocs" },
        { "include": "#string" }
      ]
    },

    "heredocs": {
      "patterns": [
        { "include": "#heredoc-mt-format" },
        { "include": "#heredoc-format" },
        { "include": "#heredoc-glsl-cstr" },
        { "include": "#heredoc-glsl" },
        { "include": "#heredoc-mt-cstr" },
        { "include": "#heredoc-mt" },
        { "include": "#heredoc-jsonc-cstr" },
        { "include": "#heredoc-jsonc" },
        { "include": "#heredoc-json-cstr" },
        { "include": "#heredoc-json" },
        { "include": "#heredoc-sql-cstr" },
        { "include": "#heredoc-sql" },
        { "include": "#heredoc-html-cstr" },
        { "include": "#heredoc-html" },
        { "include": "#heredoc-cstr" },
        { "include": "#heredoc" }
      ]
    },

    "format-string": {
      "name": "string.quoted.double.format.milk-tea",
      "begin": "f\"",
      "end": "\"",
      "patterns": [
        {
          "name": "meta.embedded.expression.milk-tea",
          "begin": "#\\{",
          "end": "\\}",
          "beginCaptures": { "0": { "name": "punctuation.section.embedded.begin.milk-tea" } },
          "endCaptures":   { "0": { "name": "punctuation.section.embedded.end.milk-tea" } },
          "patterns": [
            { "include": "#comments" },
            { "include": "#numbers" },
            { "include": "#attribute-application" },
            { "include": "#keyword-operator" },
            { "include": "#keyword-modifier" },
            { "include": "#keyword-builtin" },
            { "include": "#keyword-control" },
            { "include": "#type-constructor" },
            { "include": "#type-primitive" },
            { "include": "#constant-language" },
            { "include": "#function-call" },
            { "include": "#type-name" },
            { "include": "#identifier" },
            { "include": "#operator" },
            { "include": "#punctuation" }
          ]
        },
        {
          "name": "constant.character.escape.milk-tea",
          "match": "\\\\[nrt\\\\\"0{]"
        },
        {
          "name": "constant.character.escape.milk-tea",
          "match": "\\\\x[0-9a-fA-F]{2}"
        },
        {
          "name": "invalid.illegal.escape.milk-tea",
          "match": "\\\\."
        }
      ]
    },

    "cstring": {
      "name": "string.quoted.double.c.milk-tea",
      "begin": "c\"",
      "end": "\"",
      "patterns": [
        {
          "name": "constant.character.escape.milk-tea",
          "match": "\\\\[nrt\\\\\"0]"
        },
        {
          "name": "constant.character.escape.milk-tea",
          "match": "\\\\x[0-9a-fA-F]{2}"
        },
        {
          "name": "invalid.illegal.escape.milk-tea",
          "match": "\\\\."
        }
      ]
    },

    "string": {
      "name": "string.quoted.double.milk-tea",
      "begin": "\"",
      "end": "\"",
      "patterns": [
        {
          "name": "constant.character.escape.milk-tea",
          "match": "\\\\[nrt\\\\\"0]"
        },
        {
          "name": "constant.character.escape.milk-tea",
          "match": "\\\\x[0-9a-fA-F]{2}"
        },
        {
          "name": "invalid.illegal.escape.milk-tea",
          "match": "\\\\."
        }
      ]
    },

    "character-literal": {
      "name": "constant.character.milk-tea",
      "begin": "'",
      "end": "'",
      "patterns": [
        {
          "name": "constant.character.escape.milk-tea",
          "match": "\\\\[nrt\\\\'\"0]"
        },
        {
          "name": "constant.character.escape.milk-tea",
          "match": "\\\\x[0-9a-fA-F]{2}"
        },
        {
          "name": "invalid.illegal.escape.milk-tea",
          "match": "\\\\."
        }
      ]
    },

    "heredoc-glsl-cstr": {
      "name": "meta.embedded.block.glsl.milk-tea",
      "begin": "\\b(c<<-)((?:GLSL|VERT|FRAG|COMP))\\s*$",
      "beginCaptures": {
        "1": { "name": "punctuation.definition.string.begin.milk-tea" },
        "2": { "name": "punctuation.definition.string.begin.milk-tea" }
      },
      "contentName": "meta.embedded.block.glsl.milk-tea",
      "end": "^\\s*\\2\\s*$",
      "endCaptures": {
        "0": { "name": "punctuation.definition.string.end.milk-tea" }
      },
      "patterns": [
        { "include": "source.glsl" }
      ]
    },

    "heredoc-glsl": {
      "name": "meta.embedded.block.glsl.milk-tea",
      "begin": "(?<![A-Za-z0-9_])(<<-)((?:GLSL|VERT|FRAG|COMP))\\s*$",
      "beginCaptures": {
        "1": { "name": "punctuation.definition.string.begin.milk-tea" },
        "2": { "name": "punctuation.definition.string.begin.milk-tea" }
      },
      "contentName": "meta.embedded.block.glsl.milk-tea",
      "end": "^\\s*\\2\\s*$",
      "endCaptures": {
        "0": { "name": "punctuation.definition.string.end.milk-tea" }
      },
      "patterns": [
        { "include": "source.glsl" }
      ]
    },

    "heredoc-json-cstr": {
      "name": "meta.embedded.block.json.milk-tea",
      "begin": "\\b(c<<-)(JSON)\\s*$",
      "beginCaptures": {
        "1": { "name": "punctuation.definition.string.begin.milk-tea" },
        "2": { "name": "punctuation.definition.string.begin.milk-tea" }
      },
      "contentName": "meta.embedded.block.json.milk-tea",
      "end": "^\\s*\\2\\s*$",
      "endCaptures": {
        "0": { "name": "punctuation.definition.string.end.milk-tea" }
      },
      "patterns": [
        { "include": "source.json" }
      ]
    },

    "heredoc-json": {
      "name": "meta.embedded.block.json.milk-tea",
      "begin": "(?<![A-Za-z0-9_])(<<-)(JSON)\\s*$",
      "beginCaptures": {
        "1": { "name": "punctuation.definition.string.begin.milk-tea" },
        "2": { "name": "punctuation.definition.string.begin.milk-tea" }
      },
      "contentName": "meta.embedded.block.json.milk-tea",
      "end": "^\\s*\\2\\s*$",
      "endCaptures": {
        "0": { "name": "punctuation.definition.string.end.milk-tea" }
      },
      "patterns": [
        { "include": "source.json" }
      ]
    },

    "heredoc-jsonc-cstr": {
      "name": "meta.embedded.block.jsonc.milk-tea",
      "begin": "\\b(c<<-)(JSONC)\\s*$",
      "beginCaptures": {
        "1": { "name": "punctuation.definition.string.begin.milk-tea" },
        "2": { "name": "punctuation.definition.string.begin.milk-tea" }
      },
      "contentName": "meta.embedded.block.jsonc.milk-tea",
      "end": "^\\s*\\2\\s*$",
      "endCaptures": {
        "0": { "name": "punctuation.definition.string.end.milk-tea" }
      },
      "patterns": [
        { "include": "source.jsonc" }
      ]
    },

    "heredoc-jsonc": {
      "name": "meta.embedded.block.jsonc.milk-tea",
      "begin": "(?<![A-Za-z0-9_])(<<-)(JSONC)\\s*$",
      "beginCaptures": {
        "1": { "name": "punctuation.definition.string.begin.milk-tea" },
        "2": { "name": "punctuation.definition.string.begin.milk-tea" }
      },
      "contentName": "meta.embedded.block.jsonc.milk-tea",
      "end": "^\\s*\\2\\s*$",
      "endCaptures": {
        "0": { "name": "punctuation.definition.string.end.milk-tea" }
      },
      "patterns": [
        { "include": "source.jsonc" }
      ]
    },

    "heredoc-sql-cstr": {
      "name": "meta.embedded.block.sql.milk-tea",
      "begin": "\\b(c<<-)(SQL)\\s*$",
      "beginCaptures": {
        "1": { "name": "punctuation.definition.string.begin.milk-tea" },
        "2": { "name": "punctuation.definition.string.begin.milk-tea" }
      },
      "contentName": "meta.embedded.block.sql.milk-tea",
      "end": "^\\s*\\2\\s*$",
      "endCaptures": {
        "0": { "name": "punctuation.definition.string.end.milk-tea" }
      },
      "patterns": [
        { "include": "source.sql" }
      ]
    },

    "heredoc-sql": {
      "name": "meta.embedded.block.sql.milk-tea",
      "begin": "(?<![A-Za-z0-9_])(<<-)(SQL)\\s*$",
      "beginCaptures": {
        "1": { "name": "punctuation.definition.string.begin.milk-tea" },
        "2": { "name": "punctuation.definition.string.begin.milk-tea" }
      },
      "contentName": "meta.embedded.block.sql.milk-tea",
      "end": "^\\s*\\2\\s*$",
      "endCaptures": {
        "0": { "name": "punctuation.definition.string.end.milk-tea" }
      },
      "patterns": [
        { "include": "source.sql" }
      ]
    },

    "heredoc-html-cstr": {
      "name": "meta.embedded.block.html.milk-tea",
      "begin": "\\b(c<<-)(HTML)\\s*$",
      "beginCaptures": {
        "1": { "name": "punctuation.definition.string.begin.milk-tea" },
        "2": { "name": "punctuation.definition.string.begin.milk-tea" }
      },
      "contentName": "meta.embedded.block.html.milk-tea",
      "end": "^\\s*\\2\\s*$",
      "endCaptures": {
        "0": { "name": "punctuation.definition.string.end.milk-tea" }
      },
      "patterns": [
        { "include": "text.html.basic" }
      ]
    },

    "heredoc-html": {
      "name": "meta.embedded.block.html.milk-tea",
      "begin": "(?<![A-Za-z0-9_])(<<-)(HTML)\\s*$",
      "beginCaptures": {
        "1": { "name": "punctuation.definition.string.begin.milk-tea" },
        "2": { "name": "punctuation.definition.string.begin.milk-tea" }
      },
      "contentName": "meta.embedded.block.html.milk-tea",
      "end": "^\\s*\\2\\s*$",
      "endCaptures": {
        "0": { "name": "punctuation.definition.string.end.milk-tea" }
      },
      "patterns": [
        { "include": "text.html.basic" }
      ]
    },

    "heredoc-mt-cstr": {
      "name": "meta.embedded.block.milk-tea",
      "begin": "\\b(c<<-)(MT)\\s*$",
      "beginCaptures": {
        "1": { "name": "punctuation.definition.string.begin.milk-tea" },
        "2": { "name": "punctuation.definition.string.begin.milk-tea" }
      },
      "contentName": "meta.embedded.block.milk-tea",
      "end": "^\\s*\\2\\s*$",
      "endCaptures": {
        "0": { "name": "punctuation.definition.string.end.milk-tea" }
      },
      "patterns": [
        { "include": "source.milk-tea" }
      ]
    },

    "heredoc-mt": {
      "name": "meta.embedded.block.milk-tea",
      "begin": "(?<![A-Za-z0-9_])(<<-)(MT)\\s*$",
      "beginCaptures": {
        "1": { "name": "punctuation.definition.string.begin.milk-tea" },
        "2": { "name": "punctuation.definition.string.begin.milk-tea" }
      },
      "contentName": "meta.embedded.block.milk-tea",
      "end": "^\\s*\\2\\s*$",
      "endCaptures": {
        "0": { "name": "punctuation.definition.string.end.milk-tea" }
      },
      "patterns": [
        { "include": "source.milk-tea" }
      ]
    },

    "heredoc-mt-format": {
      "name": "meta.embedded.block.milk-tea",
      "begin": "(?<![A-Za-z0-9_])(f<<-)(MT)\\s*$",
      "beginCaptures": {
        "1": { "name": "punctuation.definition.string.begin.milk-tea" },
        "2": { "name": "punctuation.definition.string.begin.milk-tea" }
      },
      "contentName": "meta.embedded.block.milk-tea",
      "end": "^\\s*\\2\\s*$",
      "endCaptures": {
        "0": { "name": "punctuation.definition.string.end.milk-tea" }
      },
      "patterns": [
        { "include": "source.milk-tea" }
      ]
    },

    "heredoc-format": {
      "name": "string.unquoted.heredoc.format.milk-tea",
      "begin": "(?<![A-Za-z0-9_])(f<<-)([A-Za-z_][A-Za-z0-9_]*)\\s*$",
      "beginCaptures": {
        "1": { "name": "punctuation.definition.string.begin.milk-tea" },
        "2": { "name": "punctuation.definition.string.begin.milk-tea" }
      },
      "contentName": "string.unquoted.heredoc.format.milk-tea",
      "end": "^\\s*\\2\\s*$",
      "endCaptures": {
        "0": { "name": "punctuation.definition.string.end.milk-tea" }
      },
      "patterns": [
        {
          "name": "meta.embedded.expression.milk-tea",
          "begin": "#\\{",
          "end": "\\}",
          "beginCaptures": { "0": { "name": "punctuation.section.embedded.begin.milk-tea" } },
          "endCaptures":   { "0": { "name": "punctuation.section.embedded.end.milk-tea" } },
          "patterns": [
            { "include": "#comments" },
            { "include": "#numbers" },
            { "include": "#attribute-application" },
            { "include": "#keyword-operator" },
            { "include": "#keyword-modifier" },
            { "include": "#keyword-builtin" },
            { "include": "#keyword-control" },
            { "include": "#type-constructor" },
            { "include": "#type-primitive" },
            { "include": "#constant-language" },
            { "include": "#function-call" },
            { "include": "#type-name" },
            { "include": "#identifier" },
            { "include": "#operator" },
            { "include": "#punctuation" }
          ]
        },
        {
          "name": "constant.character.escape.milk-tea",
          "match": "\\\\[nrt\\\\\"0{]"
        }
      ]
    },

    "heredoc-cstr": {
      "name": "string.unquoted.heredoc.c.milk-tea",
      "begin": "\\b(c<<-)([A-Za-z_][A-Za-z0-9_]*)\\s*$",
      "beginCaptures": {
        "1": { "name": "punctuation.definition.string.begin.milk-tea" },
        "2": { "name": "punctuation.definition.string.begin.milk-tea" }
      },
      "contentName": "string.unquoted.heredoc.c.milk-tea",
      "end": "^\\s*\\2\\s*$",
      "endCaptures": {
        "0": { "name": "punctuation.definition.string.end.milk-tea" }
      },
      "patterns": [
        {
          "name": "constant.character.escape.milk-tea",
          "match": "\\\\[nrt\\\\\"0]"
        },
        {
          "name": "invalid.illegal.escape.milk-tea",
          "match": "\\\\."
        }
      ]
    },

    "heredoc": {
      "name": "string.unquoted.heredoc.milk-tea",
      "begin": "(?<![A-Za-z0-9_])(<<-)([A-Za-z_][A-Za-z0-9_]*)\\s*$",
      "beginCaptures": {
        "1": { "name": "punctuation.definition.string.begin.milk-tea" },
        "2": { "name": "punctuation.definition.string.begin.milk-tea" }
      },
      "contentName": "string.unquoted.heredoc.milk-tea",
      "end": "^\\s*\\2\\s*$",
      "endCaptures": {
        "0": { "name": "punctuation.definition.string.end.milk-tea" }
      },
      "patterns": [
        {
          "name": "constant.character.escape.milk-tea",
          "match": "\\\\[nrt\\\\\"0]"
        },
        {
          "name": "invalid.illegal.escape.milk-tea",
          "match": "\\\\."
        }
      ]
    },

    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.float.milk-tea",
          "match": "\\b[0-9][0-9_]*\\.[0-9][0-9_]*(?:[eE][+-]?[0-9]+)?(?:[fd]\\b)?"
        },
        {
          "name": "constant.numeric.hex.milk-tea",
          "match": "\\b0x[0-9a-fA-F][0-9a-fA-F_]*\\b"
        },
        {
          "name": "constant.numeric.binary.milk-tea",
          "match": "\\b0b[01][01_]*\\b"
        },
        {
          "name": "constant.numeric.integer.milk-tea",
          "match": "\\b(?:0|[1-9][0-9_]*)(?:[iIuUlLzZ][a-z]*)?\\b"
        }
      ]
    },

    "attribute-application": {
      "name": "meta.annotation.milk-tea",
      "begin": "@\\[",
      "beginCaptures": {
        "0": { "name": "punctuation.definition.annotation.begin.milk-tea" }
      },
      "end": "\\]",
      "endCaptures": {
        "0": { "name": "punctuation.definition.annotation.end.milk-tea" }
      },
      "patterns": [
        {
          "name": "entity.name.annotation.milk-tea",
          "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\b(?=\\s*(?:\\.|\\(|,|\\]))"
        },
        { "include": "#comments" },
        { "include": "#strings-and-heredocs" },
        { "include": "#numbers" },
        { "include": "#keyword-operator" },
        { "include": "#type-primitive" },
        { "include": "#constant-language" },
        { "include": "#identifier" },
        { "include": "#operator" },
        { "include": "#punctuation" }
      ]
    },

    "attribute-declaration": {
      "match": "\\b(attribute)\\s*\\[[^\\]]*\\]\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\b",
      "captures": {
        "1": { "name": "keyword.declaration.milk-tea" },
        "2": { "name": "entity.name.annotation.milk-tea" }
      }
    },

    "keyword-control": {
      "name": "keyword.control.milk-tea",
      "match": "\\b(if|else|for|in|while|break|continue|pass|return|match|defer|unsafe|await|when|parallel|gather|detach)\\b"
    },

    "keyword-declaration": {
      "name": "keyword.declaration.milk-tea",
      "match": "\\b(module|import|function|fn|proc|struct|union|enum|flags|variant|opaque|interface|extending|type|attribute|const|let|var|event|external|foreign|static|static_assert|compiler_flag|include|link|dyn|emit|inline|field_of|fields_of|callable_of|has_attribute|attribute_of|attribute_arg|attributes_of|members_of)\\b"
    },

    "keyword-operator": {
      "name": "keyword.operator.word.milk-tea",
      "match": "\\b(and|or|not|is|as|in|implements|size_of|align_of|offset_of|consuming|inout|out)\\b"
    },

    "keyword-modifier": {
      "name": "storage.modifier.milk-tea",
      "match": "\\b(public|async|editable)\\b"
    },

    "keyword-builtin": {
      "name": "support.function.builtin.milk-tea",
      "match": "\\b(ref_of|const_ptr_of|ptr_of|read|fatal|reinterpret|zero|default|adapt|get)\\b"
    },

    "type-constructor": {
      "name": "storage.type.constructor.milk-tea",
      "match": "\\b(ptr|const_ptr|ref|span|array|str_buffer|Task|Option|Result|SoA|atomic)\\b"
    },

    "type-primitive": {
      "name": "support.type.primitive.milk-tea",
      "match": "\\b(bool|byte|ubyte|char|short|ushort|int|uint|long|ulong|ptr_int|ptr_uint|float|double|void|str|cstr|vec2|vec3|vec4|ivec2|ivec3|ivec4|mat3|mat4|quat)\\b"
    },

    "constant-language": {
      "patterns": [
        {
          "name": "constant.language.boolean.milk-tea",
          "match": "\\b(true|false)\\b"
        },
        {
          "name": "constant.language.null.milk-tea",
          "match": "\\bnull\\b"
        },
        {
          "name": "variable.language.self.milk-tea",
          "match": "\\bthis\\b"
        }
      ]
    },

    "function-definition": {
      "begin": "\\b((?:const\\s+|async\\s+|foreign\\s+|external\\s+|editable\\s+)*function)\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
      "beginCaptures": {
        "1": { "name": "keyword.declaration.milk-tea" },
        "2": { "name": "entity.name.function.milk-tea" }
      },
      "end": "(?=:\\s*(?:#.*)?$)",
      "patterns": [
        { "include": "#comments" },
        { "include": "#function-type-params" },
        { "include": "#function-parameters" },
        { "include": "#type-constructor" },
        { "include": "#type-primitive" },
        { "include": "#type-name" },
        { "include": "#keyword-operator" },
        { "include": "#keyword-modifier" },
        { "include": "#operator" },
        { "include": "#punctuation" }
      ]
    },

    "function-type-params": {
      "name": "meta.function.type-parameters.milk-tea",
      "begin": "\\[",
      "end": "\\]",
      "beginCaptures": { "0": { "name": "punctuation.section.bracket.begin.milk-tea" } },
      "endCaptures":   { "0": { "name": "punctuation.section.bracket.end.milk-tea" } },
      "patterns": [
        { "include": "#type-constructor" },
        { "include": "#type-primitive" },
        { "include": "#keyword-operator" },
        { "include": "#type-name" },
        { "include": "#identifier" },
        { "include": "#operator" },
        { "include": "#punctuation" }
      ]
    },

    "function-parameters": {
      "name": "meta.function.parameters.milk-tea",
      "begin": "\\(",
      "end": "\\)",
      "beginCaptures": { "0": { "name": "punctuation.section.parens.begin.milk-tea" } },
      "endCaptures":   { "0": { "name": "punctuation.section.parens.end.milk-tea" } },
      "patterns": [
        {
          "name": "variable.parameter.milk-tea",
          "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\s*(?=:|,|\\))"
        },
        { "include": "#type-constructor" },
        { "include": "#type-primitive" },
        { "include": "#keyword-modifier" },
        { "include": "#keyword-operator" },
        { "include": "#constant-language" },
        { "include": "#type-name" },
        { "include": "#identifier" },
        { "include": "#operator" },
        { "include": "#punctuation" }
      ]
    },

    "function-call": {
      "name": "entity.name.function.milk-tea",
      "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\s*(?=\\()"
    },

    "type-name": {
      "patterns": [
        {
          "comment": "Return type after arrow",
          "match": "(?<=->)\\s*([a-zA-Z_][a-zA-Z0-9_.]*(?:\\[[^\\]]*\\])?(?:\\?)?)",
          "captures": {
            "1": { "name": "entity.name.type.milk-tea" }
          }
        },
        {
          "comment": "Type annotation after colon in let/var/const declarations",
          "match": "(?:\\b(?:public\\s+)?(?:let|var|const)\\s+[a-zA-Z_][a-zA-Z0-9_]*\\s*:\\s*)([a-zA-Z_][a-zA-Z0-9_.]*(?:\\[[^\\]]*\\])?(?:\\?)?)",
          "captures": {
            "1": { "name": "entity.name.type.milk-tea" }
          }
        },
        {
          "comment": "UpperCamelCase names",
          "name": "entity.name.type.milk-tea",
          "match": "\\b([A-Z][a-zA-Z0-9_]*)\\b"
        }
      ]
    },

    "field-declaration": {
      "name": "variable.other.member.milk-tea",
      "match": "^\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\s*(?=:)"
    },

    "identifier": {
      "name": "variable.other.milk-tea",
      "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\b"
    },

    "operator": {
      "patterns": [
        {
          "name": "keyword.operator.comparison.milk-tea",
          "match": "(==|!=|<=|>=|<|>)"
        },
        {
          "name": "keyword.operator.assignment.milk-tea",
          "match": "(\\+=|-=|\\*=|/=|%=|&=|\\|=|\\^=|<<=|>>=|=)(?!=)"
        },
        {
          "name": "keyword.operator.arithmetic.milk-tea",
          "match": "(\\+|-|\\*|/|%)"
        },
        {
          "name": "keyword.operator.bitwise.milk-tea",
          "match": "(&|\\||\\^|~|<<|>>)"
        },
        {
          "name": "keyword.operator.arrow.milk-tea",
          "match": "->"
        },
        {
          "name": "keyword.operator.dot.milk-tea",
          "match": "\\."
        },
        {
          "name": "keyword.operator.range.milk-tea",
          "match": "\\.\\."
        },
        {
          "name": "keyword.operator.optional.milk-tea",
          "match": "\\?"
        }
      ]
    },

    "punctuation": {
      "patterns": [
        { "name": "punctuation.separator.comma.milk-tea",     "match": "," },
        { "name": "punctuation.separator.colon.milk-tea",     "match": ":" },
        { "name": "punctuation.separator.semicolon.milk-tea", "match": ";" },
        { "name": "punctuation.definition.variadic.milk-tea", "match": "\\.\\.\\." },
        { "name": "punctuation.section.parens.begin.milk-tea","match": "\\(" },
        { "name": "punctuation.section.parens.end.milk-tea",  "match": "\\)" },
        { "name": "punctuation.section.bracket.begin.milk-tea","match": "\\[" },
        { "name": "punctuation.section.bracket.end.milk-tea", "match": "\\]" }
      ]
    }
  }
}
