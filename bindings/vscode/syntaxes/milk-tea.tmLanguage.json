{
  "$schema": "https://json.schemastore.org/tmlanguage.json",
  "name": "Milk Tea",
  "scopeName": "source.milk-tea",
  "fileTypes": ["mt"],
  "patterns": [
    { "include": "#comment" },
    { "include": "#format-string" },
    { "include": "#cstring" },
    { "include": "#format-html-heredoc-string" },
    { "include": "#format-heredoc-string" },
    { "include": "#glsl-heredoc-cstring" },
    { "include": "#glsl-heredoc-string" },
    { "include": "#json-heredoc-cstring" },
    { "include": "#json-heredoc-string" },
    { "include": "#jsonc-heredoc-cstring" },
    { "include": "#jsonc-heredoc-string" },
    { "include": "#sql-heredoc-cstring" },
    { "include": "#sql-heredoc-string" },
    { "include": "#html-heredoc-cstring" },
    { "include": "#html-heredoc-string" },
    { "include": "#heredoc-cstring" },
    { "include": "#heredoc-string" },
    { "include": "#string" },
    { "include": "#character-literal" },
    { "include": "#number" },
    { "include": "#attribute-application" },
    { "include": "#keyword-control" },
    { "include": "#attribute-declaration" },
    { "include": "#keyword-declaration" },
    { "include": "#keyword-operator" },
    { "include": "#keyword-modifier" },
    { "include": "#keyword-builtin" },
    { "include": "#type-primitive" },
    { "include": "#constant-language" },
    { "include": "#function-definition" },
    { "include": "#function-call" },
    { "include": "#type-name" },
    { "include": "#identifier" },
    { "include": "#operator" },
    { "include": "#punctuation" }
  ],
  "repository": {
    "comment": {
      "name": "comment.line.number-sign.milk-tea",
      "match": "#.*$"
    },

    "cstring": {
      "name": "string.quoted.double.c.milk-tea",
      "begin": "c\"",
      "end": "\"",
      "patterns": [
        {
          "name": "constant.character.escape.milk-tea",
          "match": "\\\\[nrt\\\\\"0]"
        },
        {
          "name": "invalid.illegal.escape.milk-tea",
          "match": "\\\\."
        }
      ]
    },

    "character-literal": {
      "name": "constant.character.milk-tea",
      "begin": "'",
      "end": "'",
      "patterns": [
        {
          "name": "constant.character.escape.milk-tea",
          "match": "\\\\[nrt\\\\'\"0]"
        },
        {
          "name": "constant.character.escape.milk-tea",
          "match": "\\\\x[0-9a-fA-F]{2}"
        },
        {
          "name": "invalid.illegal.escape.milk-tea",
          "match": "\\\\."
        }
      ]
    },

    "format-string": {
      "name": "string.quoted.double.format.milk-tea",
      "begin": "f\"",
      "end": "\"",
      "patterns": [
        {
          "name": "meta.embedded.expression.milk-tea",
          "begin": "#\\{",
          "end": "\\}",
          "beginCaptures": { "0": { "name": "punctuation.section.embedded.begin.milk-tea" } },
          "endCaptures":   { "0": { "name": "punctuation.section.embedded.end.milk-tea" } },
          "patterns": [
            { "include": "#comment" },
            { "include": "#number" },
            { "include": "#attribute-application" },
            { "include": "#keyword-control" },
            { "include": "#keyword-operator" },
            { "include": "#keyword-modifier" },
            { "include": "#keyword-builtin" },
            { "include": "#type-primitive" },
            { "include": "#constant-language" },
            { "include": "#function-call" },
            { "include": "#type-name" },
            { "include": "#identifier" },
            { "include": "#operator" },
            { "include": "#punctuation" }
          ]
        },
        {
          "name": "constant.character.escape.milk-tea",
          "match": "\\\\[nrt\\\\\"0{]"
        }
      ]
    },

    "glsl-heredoc-cstring": {
      "name": "meta.embedded.block.glsl.milk-tea",
      "begin": "\\b(c<<-)((?:GLSL|VERT|FRAG|COMP))\\s*$",
      "beginCaptures": {
        "1": { "name": "punctuation.definition.string.begin.milk-tea" },
        "2": { "name": "punctuation.definition.string.begin.milk-tea" }
      },
      "contentName": "meta.embedded.block.glsl.milk-tea",
      "end": "^\\s*\\2\\s*$",
      "endCaptures": {
        "0": { "name": "punctuation.definition.string.end.milk-tea" }
      },
      "patterns": [
        { "include": "source.glsl" }
      ]
    },

    "glsl-heredoc-string": {
      "name": "meta.embedded.block.glsl.milk-tea",
      "begin": "(?<![A-Za-z0-9_])(<<-)((?:GLSL|VERT|FRAG|COMP))\\s*$",
      "beginCaptures": {
        "1": { "name": "punctuation.definition.string.begin.milk-tea" },
        "2": { "name": "punctuation.definition.string.begin.milk-tea" }
      },
      "contentName": "meta.embedded.block.glsl.milk-tea",
      "end": "^\\s*\\2\\s*$",
      "endCaptures": {
        "0": { "name": "punctuation.definition.string.end.milk-tea" }
      },
      "patterns": [
        { "include": "source.glsl" }
      ]
    },

    "json-heredoc-cstring": {
      "name": "meta.embedded.block.json.milk-tea",
      "begin": "\\b(c<<-)(JSON)\\s*$",
      "beginCaptures": {
        "1": { "name": "punctuation.definition.string.begin.milk-tea" },
        "2": { "name": "punctuation.definition.string.begin.milk-tea" }
      },
      "contentName": "meta.embedded.block.json.milk-tea",
      "end": "^\\s*\\2\\s*$",
      "endCaptures": {
        "0": { "name": "punctuation.definition.string.end.milk-tea" }
      },
      "patterns": [
        { "include": "source.json" }
      ]
    },

    "json-heredoc-string": {
      "name": "meta.embedded.block.json.milk-tea",
      "begin": "(?<![A-Za-z0-9_])(<<-)(JSON)\\s*$",
      "beginCaptures": {
        "1": { "name": "punctuation.definition.string.begin.milk-tea" },
        "2": { "name": "punctuation.definition.string.begin.milk-tea" }
      },
      "contentName": "meta.embedded.block.json.milk-tea",
      "end": "^\\s*\\2\\s*$",
      "endCaptures": {
        "0": { "name": "punctuation.definition.string.end.milk-tea" }
      },
      "patterns": [
        { "include": "source.json" }
      ]
    },

    "jsonc-heredoc-cstring": {
      "name": "meta.embedded.block.jsonc.milk-tea",
      "begin": "\\b(c<<-)(JSONC)\\s*$",
      "beginCaptures": {
        "1": { "name": "punctuation.definition.string.begin.milk-tea" },
        "2": { "name": "punctuation.definition.string.begin.milk-tea" }
      },
      "contentName": "meta.embedded.block.jsonc.milk-tea",
      "end": "^\\s*\\2\\s*$",
      "endCaptures": {
        "0": { "name": "punctuation.definition.string.end.milk-tea" }
      },
      "patterns": [
        { "include": "source.jsonc" }
      ]
    },

    "jsonc-heredoc-string": {
      "name": "meta.embedded.block.jsonc.milk-tea",
      "begin": "(?<![A-Za-z0-9_])(<<-)(JSONC)\\s*$",
      "beginCaptures": {
        "1": { "name": "punctuation.definition.string.begin.milk-tea" },
        "2": { "name": "punctuation.definition.string.begin.milk-tea" }
      },
      "contentName": "meta.embedded.block.jsonc.milk-tea",
      "end": "^\\s*\\2\\s*$",
      "endCaptures": {
        "0": { "name": "punctuation.definition.string.end.milk-tea" }
      },
      "patterns": [
        { "include": "source.jsonc" }
      ]
    },

    "sql-heredoc-cstring": {
      "name": "meta.embedded.block.sql.milk-tea",
      "begin": "\\b(c<<-)(SQL)\\s*$",
      "beginCaptures": {
        "1": { "name": "punctuation.definition.string.begin.milk-tea" },
        "2": { "name": "punctuation.definition.string.begin.milk-tea" }
      },
      "contentName": "meta.embedded.block.sql.milk-tea",
      "end": "^\\s*\\2\\s*$",
      "endCaptures": {
        "0": { "name": "punctuation.definition.string.end.milk-tea" }
      },
      "patterns": [
        { "include": "source.sql" }
      ]
    },

    "sql-heredoc-string": {
      "name": "meta.embedded.block.sql.milk-tea",
      "begin": "(?<![A-Za-z0-9_])(<<-)(SQL)\\s*$",
      "beginCaptures": {
        "1": { "name": "punctuation.definition.string.begin.milk-tea" },
        "2": { "name": "punctuation.definition.string.begin.milk-tea" }
      },
      "contentName": "meta.embedded.block.sql.milk-tea",
      "end": "^\\s*\\2\\s*$",
      "endCaptures": {
        "0": { "name": "punctuation.definition.string.end.milk-tea" }
      },
      "patterns": [
        { "include": "source.sql" }
      ]
    },

    "heredoc-cstring": {
      "name": "string.unquoted.heredoc.c.milk-tea",
      "begin": "\\b(c<<-)([A-Za-z_][A-Za-z0-9_]*)\\s*$",
      "beginCaptures": {
        "1": { "name": "punctuation.definition.string.begin.milk-tea" },
        "2": { "name": "punctuation.definition.string.begin.milk-tea" }
      },
      "contentName": "string.unquoted.heredoc.c.milk-tea",
      "end": "^\\s*\\2\\s*$",
      "endCaptures": {
        "0": { "name": "punctuation.definition.string.end.milk-tea" }
      },
      "patterns": [
        {
          "name": "constant.character.escape.milk-tea",
          "match": "\\\\[nrt\\\\\"0]"
        },
        {
          "name": "invalid.illegal.escape.milk-tea",
          "match": "\\\\."
        }
      ]
    },

    "format-heredoc-string": {
      "name": "string.unquoted.heredoc.format.milk-tea",
      "begin": "(?<![A-Za-z0-9_])(f<<-)([A-Za-z_][A-Za-z0-9_]*)\\s*$",
      "beginCaptures": {
        "1": { "name": "punctuation.definition.string.begin.milk-tea" },
        "2": { "name": "punctuation.definition.string.begin.milk-tea" }
      },
      "contentName": "string.unquoted.heredoc.format.milk-tea",
      "end": "^\\s*\\2\\s*$",
      "endCaptures": {
        "0": { "name": "punctuation.definition.string.end.milk-tea" }
      },
      "patterns": [
        {
          "name": "meta.embedded.expression.milk-tea",
          "begin": "#\\{",
          "end": "\\}",
          "beginCaptures": { "0": { "name": "punctuation.section.embedded.begin.milk-tea" } },
          "endCaptures":   { "0": { "name": "punctuation.section.embedded.end.milk-tea" } },
          "patterns": [
            { "include": "#comment" },
            { "include": "#number" },
            { "include": "#attribute-application" },
            { "include": "#keyword-control" },
            { "include": "#keyword-operator" },
            { "include": "#keyword-modifier" },
            { "include": "#keyword-builtin" },
            { "include": "#type-primitive" },
            { "include": "#constant-language" },
            { "include": "#function-call" },
            { "include": "#type-name" },
            { "include": "#identifier" },
            { "include": "#operator" },
            { "include": "#punctuation" }
          ]
        },
        {
          "name": "constant.character.escape.milk-tea",
          "match": "\\\\[nrt\\\\\"0{]"
        }
      ]
    },

    "html-heredoc-cstring": {
      "name": "string.unquoted.heredoc.milk-tea",
      "begin": "\\b(c<<-)(HTML)\\s*$",
      "beginCaptures": {
        "1": { "name": "punctuation.definition.string.begin.milk-tea" },
        "2": { "name": "punctuation.definition.string.begin.milk-tea" }
      },
      "contentName": "meta.embedded.block.html.milk-tea",
      "end": "^\\s*\\2\\s*$",
      "endCaptures": {
        "0": { "name": "punctuation.definition.string.end.milk-tea" }
      },
      "patterns": [
        {
          "name": "constant.character.escape.milk-tea",
          "match": "\\\\[nrt\\\\\"0]"
        },
        {
          "name": "invalid.illegal.escape.milk-tea",
          "match": "\\\\."
        },
        { "include": "text.html.basic" }
      ]
    },

    "html-heredoc-string": {
      "name": "string.unquoted.heredoc.milk-tea",
      "begin": "(?<![A-Za-z0-9_])(<<-)(HTML)\\s*$",
      "beginCaptures": {
        "1": { "name": "punctuation.definition.string.begin.milk-tea" },
        "2": { "name": "punctuation.definition.string.begin.milk-tea" }
      },
      "contentName": "meta.embedded.block.html.milk-tea",
      "end": "^\\s*\\2\\s*$",
      "endCaptures": {
        "0": { "name": "punctuation.definition.string.end.milk-tea" }
      },
      "patterns": [
        {
          "name": "constant.character.escape.milk-tea",
          "match": "\\\\[nrt\\\\\"0]"
        },
        {
          "name": "invalid.illegal.escape.milk-tea",
          "match": "\\\\."
        },
        { "include": "text.html.basic" }
      ]
    },

    "heredoc-string": {
      "name": "string.unquoted.heredoc.milk-tea",
      "begin": "(?<![A-Za-z0-9_])(<<-)([A-Za-z_][A-Za-z0-9_]*)\\s*$",
      "beginCaptures": {
        "1": { "name": "punctuation.definition.string.begin.milk-tea" },
        "2": { "name": "punctuation.definition.string.begin.milk-tea" }
      },
      "contentName": "string.unquoted.heredoc.milk-tea",
      "end": "^\\s*\\2\\s*$",
      "endCaptures": {
        "0": { "name": "punctuation.definition.string.end.milk-tea" }
      },
      "patterns": [
        {
          "name": "constant.character.escape.milk-tea",
          "match": "\\\\[nrt\\\\\"0]"
        },
        {
          "name": "invalid.illegal.escape.milk-tea",
          "match": "\\\\."
        }
      ]
    },

    "string": {
      "name": "string.quoted.double.milk-tea",
      "begin": "\"",
      "end": "\"",
      "patterns": [
        {
          "name": "constant.character.escape.milk-tea",
          "match": "\\\\[nrt\\\\\"0]"
        },
        {
          "name": "invalid.illegal.escape.milk-tea",
          "match": "\\\\."
        }
      ]
    },

    "number": {
      "patterns": [
        {
          "name": "constant.numeric.float.milk-tea",
          "match": "\\b[0-9][0-9_]*\\.[0-9][0-9_]*(?:[eE][+-]?[0-9]+)?\\b"
        },
        {
          "name": "constant.numeric.hex.milk-tea",
          "match": "\\b0x[0-9a-fA-F][0-9a-fA-F_]*\\b"
        },
        {
          "name": "constant.numeric.binary.milk-tea",
          "match": "\\b0b[01][01_]*\\b"
        },
        {
          "name": "constant.numeric.integer.milk-tea",
          "match": "\\b[0-9][0-9_]*\\b"
        }
      ]
    },

    "attribute-application": {
      "name": "meta.annotation.milk-tea",
      "begin": "@\\[",
      "beginCaptures": {
        "0": { "name": "punctuation.definition.annotation.begin.milk-tea" }
      },
      "end": "\\]",
      "endCaptures": {
        "0": { "name": "punctuation.definition.annotation.end.milk-tea" }
      },
      "patterns": [
        {
          "name": "entity.name.annotation.milk-tea",
          "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\b(?=\\s*(?:\\.|\\(|,|\\]))"
        },
        { "include": "#comment" },
        { "include": "#format-string" },
        { "include": "#string" },
        { "include": "#number" },
        { "include": "#keyword-operator" },
        { "include": "#type-primitive" },
        { "include": "#constant-language" },
        { "include": "#identifier" },
        { "include": "#operator" },
        { "include": "#punctuation" }
      ]
    },

    "attribute-declaration": {
      "comment": "Highlight the name in `attribute[target] name(...)`",
      "match": "\\b(attribute)\\s*\\[[^\\]]*\\]\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\b",
      "captures": {
        "1": { "name": "keyword.declaration.milk-tea" },
        "2": { "name": "entity.name.annotation.milk-tea" }
      }
    },

    "keyword-control": {
      "name": "keyword.control.milk-tea",
      "match": "\\b(if|else|for|in|while|break|continue|pass|return|match|defer|unsafe|await|when|parallel|gather|detach)\\b"
    },

    "keyword-declaration": {
      "name": "keyword.declaration.milk-tea",
      "match": "\\b(module|import|function|fn|proc|struct|union|enum|flags|variant|opaque|interface|extending|type|attribute|const|let|var|event|external|foreign|static|static_assert|compiler_flag|include|link|dyn|emit|inline|field_of|fields_of|callable_of|has_attribute|attribute_of|attribute_arg|attributes_of|members_of)\\b"
    },

    "keyword-operator": {
      "name": "keyword.operator.word.milk-tea",
      "match": "\\b(and|or|not|is|as|in|implements|size_of|align_of|offset_of|consuming|inout|out)\\b"
    },

    "keyword-modifier": {
      "name": "storage.modifier.milk-tea",
      "match": "\\b(public|async|editable)\\b"
    },

    "keyword-builtin": {
      "name": "support.function.builtin.milk-tea",
      "match": "\\b(ref_of|const_ptr_of|ptr_of|read|fatal|reinterpret|zero|default|adapt|get)\\b"
    },

    "type-primitive": {
      "name": "support.type.primitive.milk-tea",
      "match": "\\b(bool|byte|ubyte|char|short|ushort|int|uint|long|ulong|ptr_int|ptr_uint|float|double|void|str|cstr|vec2|vec3|vec4|ivec2|ivec3|ivec4|mat3|mat4|quat)\\b"
    },

    "constant-language": {
      "patterns": [
        {
          "name": "constant.language.boolean.milk-tea",
          "match": "\\b(true|false)\\b"
        },
        {
          "name": "constant.language.null.milk-tea",
          "match": "\\bnull\\b"
        },
        {
          "name": "variable.language.self.milk-tea",
          "match": "\\bthis\\b"
        }
      ]
    },

    "function-definition": {
      "comment": "Highlight the name in `function myFunction(...)` including modifiers",
      "match": "\\b((?:const\\s+|async\\s+|foreign\\s+|external\\s+|editable\\s+)*function)\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\b",
      "captures": {
        "1": { "name": "keyword.declaration.milk-tea" },
        "2": { "name": "entity.name.function.milk-tea" }
      }
    },

    "function-call": {
      "comment": "Highlight calls: identifier immediately followed by `(`",
      "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)(?=\\s*\\()",
      "captures": {
        "1": { "name": "entity.name.function.milk-tea" }
      }
    },

    "type-name": {
      "comment": "Types after `:` in param/let/var positions and after `->` return position; also capitalised names",
      "patterns": [
        {
          "comment": "Return type arrow",
          "match": "(->)\\s*([a-zA-Z_][a-zA-Z0-9_.]*(?:\\[[^\\]]*\\])?)",
          "captures": {
            "1": { "name": "keyword.operator.arrow.milk-tea" },
            "2": { "name": "entity.name.type.milk-tea" }
          }
        },
        {
          "comment": "Parameter type annotation after colon",
          "match": "([,(]\\s*(?:(?:in|inout|out|consuming)\\s+)?[a-zA-Z_][a-zA-Z0-9_]*\\s*:\\s*)([a-zA-Z_][a-zA-Z0-9_.]*(?:\\[[^\\]]*\\])?(?:\\*|\\?)?)(?=\\s*(?:as\\b|,|\\)))",
          "captures": {
            "2": { "name": "entity.name.type.milk-tea" }
          }
        },
        {
          "comment": "Local or constant type annotation after colon",
          "match": "((?:\\bpublic\\s+)?(?:let|var|const)\\s+[a-zA-Z_][a-zA-Z0-9_]*\\s*:\\s*)([a-zA-Z_][a-zA-Z0-9_.]*(?:\\[[^\\]]*\\])?(?:\\*|\\?)?)(?=\\s*(?:=|$|#))",
          "captures": {
            "2": { "name": "entity.name.type.milk-tea" }
          }
        },
        {
          "comment": "Field declaration type annotation after colon",
          "match": "(^\\s*(?!(?:if|else|for|in|while|break|continue|pass|return|match|defer|unsafe|await|module|import|function|fn|proc|struct|union|enum|flags|variant|opaque|interface|extending|type|attribute|const|let|var|event|external|foreign|static|static_assert|compiler_flag|include|link|public|async|editable)\\b)[a-zA-Z_][a-zA-Z0-9_]*\\s*:\\s*)([a-zA-Z_][a-zA-Z0-9_.]*(?:\\[[^\\]]*\\])?(?:\\*|\\?)?)(?=\\s*(?:$|#))",
          "captures": {
            "2": { "name": "entity.name.type.milk-tea" }
          }
        },
        {
          "comment": "UpperCamelCase names are likely types",
          "match": "\\b([A-Z][a-zA-Z0-9_]*)\\b",
          "captures": {
            "1": { "name": "entity.name.type.milk-tea" }
          }
        }
      ]
    },

    "identifier": {
      "name": "variable.other.milk-tea",
      "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\b"
    },

    "operator": {
      "patterns": [
        {
          "name": "keyword.operator.comparison.milk-tea",
          "match": "(==|!=|<=|>=|<|>)"
        },
        {
          "name": "keyword.operator.assignment.milk-tea",
          "match": "(\\+=|-=|\\*=|/=|%=|&=|\\|=|\\^=|<<=|>>=|=)(?!=)"
        },
        {
          "name": "keyword.operator.arithmetic.milk-tea",
          "match": "(\\+|-|\\*|/|%)"
        },
        {
          "name": "keyword.operator.bitwise.milk-tea",
          "match": "(&|\\||\\^|~|<<|>>)"
        },
        {
          "name": "keyword.operator.arrow.milk-tea",
          "match": "->"
        },
        {
          "name": "keyword.operator.dot.milk-tea",
          "match": "\\."
        },
        {
          "name": "keyword.operator.range.milk-tea",
          "match": "\\.\\."
        },
