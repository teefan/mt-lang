    onInitFileW: fn(arg0: ptr[void], arg1: const_ptr[int], arg2: const_ptr[ma_decoding_backend_config], arg3: const_ptr[ma_allocation_callbacks], arg4: ptr[ptr[ma_data_source]]) -> ma_result
