        SDL_GPU_BLENDFACTOR_ONE_MINUS_SRC_ALPHA = 8
        SDL_GPU_BLENDFACTOR_DST_ALPHA = 9
        SDL_GPU_BLENDFACTOR_ONE_MINUS_DST_ALPHA = 10
        SDL_GPU_BLENDFACTOR_CONSTANT_COLOR = 11
        SDL_GPU_BLENDFACTOR_ONE_MINUS_CONSTANT_COLOR = 12
