        attack_level: ushort
        fade_length: ushort
        fade_level: ushort

    struct SDL_HapticCondition:
        kind: ushort
        direction: SDL_HapticDirection
        length: uint
        delay: ushort
        button: ushort
        interval: ushort
        right_sat: array[Uint16, 3]
        left_sat: array[Uint16, 3]
